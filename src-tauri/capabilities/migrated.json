{
  "identifier": "migrated",
  "description": "Permissions for CtxRun (v2)",
  "local": true,
  "windows": [
    "main",
    "spotlight"
  ],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-start-resize-dragging",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-set-size",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": ["$APP_LOCAL_DATA/**", "$HOME/**", "**"]
    },
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-exists",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:allow-write-file",
    "shell:default",
    "shell:allow-open",
    "dialog:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-image",
    "clipboard-manager:allow-read-image",
    "global-shortcut:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister-all",
    "global-shortcut:allow-is-registered",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:8787" },
        { "url": "http://localhost:8787" },
        { "url": "https://*/*" },
        { "url": "http://*/*" }
      ]
    },
    {
      "identifier": "shell:allow-open"
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "cmd", "cmd": "cmd", "args": true },
        { "name": "powershell", "cmd": "powershell", "args": true },
        { "name": "osascript", "cmd": "osascript", "args": true },
        { "name": "x-terminal-emulator", "cmd": "x-terminal-emulator", "args": true },
        { "name": "python", "cmd": "python", "args": true },
        { "name": "python3", "cmd": "python3", "args": true }
      ]
    },
    "core:app:allow-identifier",

    "ctxrun-plugin-automator:allow-execute-workflow",
    "ctxrun-plugin-automator:allow-execute-workflow-graph",
    "ctxrun-plugin-automator:allow-stop-workflow",
    "ctxrun-plugin-automator:allow-get-mouse-position",
    "ctxrun-plugin-automator:allow-get-pixel-color",
    "ctxrun-plugin-automator:allow-get-element-under-cursor",
    "ctxrun-plugin-automator:allow-pick-web-selector",
    "ctxrun-plugin-automator:allow-pick-web-target",
    "ctxrun-plugin-context:allow-calculate-context-stats",
    "ctxrun-plugin-context:allow-scan-for-secrets",
    "ctxrun-plugin-context:allow-get-context-content",
    "ctxrun-plugin-context:allow-copy-context-to-clipboard",
    "ctxrun-plugin-context:allow-save-context-to-file",
    "ctxrun-plugin-context:allow-scan-project-tree",
    "ctxrun-plugin-context:allow-has-ignore-files",
    "ctxrun-plugin-context:allow-get-ignored-by-protocol",
    "ctxrun-plugin-git:allow-get-git-commits",
    "ctxrun-plugin-git:allow-get-git-diff",
    "ctxrun-plugin-git:allow-get-git-diff-text",
    "ctxrun-plugin-git:allow-export-git-diff",
    "ctxrun-plugin-refinery:allow-get-refinery-history",
    "ctxrun-plugin-refinery:allow-get-refinery-item-detail",
    "ctxrun-plugin-refinery:allow-get-refinery-statistics",
    "ctxrun-plugin-refinery:allow-toggle-refinery-pin",
    "ctxrun-plugin-refinery:allow-delete-refinery-items",
    "ctxrun-plugin-refinery:allow-clear-refinery-history",
    "ctxrun-plugin-refinery:allow-copy-refinery-text",
    "ctxrun-plugin-refinery:allow-copy-refinery-image",
    "ctxrun-plugin-refinery:allow-create-note",
    "ctxrun-plugin-refinery:allow-update-note",
    "ctxrun-plugin-refinery:allow-spotlight-paste",
    "ctxrun-plugin-refinery:allow-update-cleanup-config",
    "ctxrun-plugin-refinery:allow-manual-cleanup",
    "ctxrun-plugin-miner:allow-start-mining",
    "ctxrun-plugin-miner:allow-stop-mining",
    "ctxrun-plugin-miner:allow-extract-single-page",
    "ctxrun-plugin-miner:allow-search-web",
    "ctxrun-plugin-transfer:allow-start-service",
    "ctxrun-plugin-transfer:allow-stop-service",
    "ctxrun-plugin-transfer:allow-send-message",
    "ctxrun-plugin-transfer:allow-send-file",
    "ctxrun-plugin-transfer:allow-get-devices",
    "ctxrun-plugin-transfer:allow-get-chat-history",
    "ctxrun-plugin-transfer:allow-get-network-interfaces",
    "ctxrun-plugin-transfer:allow-respond-file-request",
    "ctxrun-plugin-exec-runtime:allow-request-exec",
    "ctxrun-plugin-exec-runtime:allow-approve-exec",
    "ctxrun-plugin-exec-runtime:allow-write-exec",
    "ctxrun-plugin-exec-runtime:allow-resize-exec",
    "ctxrun-plugin-exec-runtime:allow-terminate-exec",
    "ctxrun-plugin-ocr:allow-ocr-get-status",
    "ctxrun-plugin-ocr:allow-ocr-prepare",
    "ctxrun-plugin-ocr:allow-ocr-recognize-file",
    "ctxrun-plugin-ocr:allow-ocr-recognize-bytes",
    "ctxrun-plugin-ocr:allow-ocr-release"
  ]
}
